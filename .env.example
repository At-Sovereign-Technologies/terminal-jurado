# Frontend (Vite) - Terminal de Jurado

VITE_SIDECAR_URL=http://localhost:8089
VITE_JURADO_CONFIG_PATH=/jurado-config.json

# Overrides de jurado-config.json para despliegue
VITE_JURADO_PUNTO_ID=1
VITE_JURADO_SECRETO=demo-jurado-secret
VITE_JURADO_CLUSTER_URL=http://localhost:8080

# Sidecar (Node) - exportar en el entorno del proceso sidecar
# SIDECAR_HTTP_PORT=8089
# SIDECAR_WS_VOTO_PORT=8090
# SIDECAR_WS_JURADO_PORT=8087
# NODO_URL=http://localhost:8080
# SIDECAR_DEPLOYMENT_PATH=../public/deployment.yml
# SIDECAR_TERMINAL_PUBLIC_KEY=<hex-ed25519-public-key>
# SIDECAR_JURADO_CONFIG_PATH=../public/jurado-config.json
# SIDECAR_PUNTO_ID=1
# SIDECAR_TERMINAL_GUID_MAP=1=11111111-1111-1111-1111-111111111111,2=22222222-2222-2222-2222-222222222222
# SIDECAR_TERMINAL_JWT_MAP=1=<jwt-terminal-1>,2=<jwt-terminal-2>
# SIDECAR_VOTER_GUID_MAP=1010101010=aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa,1020202020=bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb
